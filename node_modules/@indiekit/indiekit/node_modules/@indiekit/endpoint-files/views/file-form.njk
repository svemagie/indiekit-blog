{% extends "form.njk" %}

{% block form %}
  {{ heading({ text: title, parent: parent }) }}

  <div x-data="multiUpload('{{ application.mediaEndpoint }}', '{{ filesPath }}')"
       class="multi-upload"
       @dragover.prevent="dragover = true"
       @dragleave.prevent="dragover = false"
       @drop.prevent="handleDrop($event)">

    {# Drop zone #}
    <div class="multi-upload__drop-zone"
         :class="{ 'multi-upload__drop-zone--active': dragover }">
      <p class="multi-upload__drop-text">{{ __("files.upload.dropText") }}</p>
      <label class="multi-upload__browse button button--secondary">
        {{ __("files.upload.browse") }}
        <input class="multi-upload__input" type="file" name="file" multiple hidden
               @change="addFiles($event)">
      </label>
    </div>

    {# File list #}
    <ul class="multi-upload__file-list" x-show="files.length > 0" x-cloak>
      <template x-for="(file, index) in files" :key="file.id">
        <li class="multi-upload__file-item">
          <span class="multi-upload__file-name" x-text="file.name"></span>
          <span class="multi-upload__file-size" x-text="formatSize(file.size)"></span>
          <progress class="multi-upload__progress" :value="file.progress" max="100"
                    x-show="file.uploading || file.done"></progress>
          <span class="multi-upload__status multi-upload__status--success"
                x-show="file.done && !file.error">&#10003;</span>
          <span class="multi-upload__status multi-upload__status--error"
                x-show="file.error" x-text="file.error"></span>
          <button class="multi-upload__remove" type="button"
                  @click="removeFile(index)"
                  x-show="!file.uploading && !file.done"
                  aria-label="Remove">&times;</button>
        </li>
      </template>
    </ul>

    {# Upload button #}
    <button class="multi-upload__submit button" type="button"
            x-show="files.length > 0 && !allDone"
            x-cloak
            :disabled="uploading"
            @click="uploadAll()">
      <span x-show="!uploading">{{ __("files.upload.submitMultiple") }}
        (<span x-text="files.filter(f => !f.done).length"></span>)</span>
      <span x-show="uploading" x-text="uploadingText"></span>
    </button>
  </div>

  {# No-JS fallback #}
  <noscript>
    <div class="button-group">
      {{ button({
        text: __("files.form.submit"),
        attributes: { formenctype: "multipart/form-data" }
      }) }}
    </div>
  </noscript>

  <script>
  function multiUpload(endpoint, redirectPath) {
    var idCounter = 0;
    return {
      files: [],
      dragover: false,
      uploading: false,
      allDone: false,
      uploadingText: '',

      addFiles(event) {
        for (var i = 0; i < event.target.files.length; i++) {
          var file = event.target.files[i];
          this.files.push({
            id: ++idCounter,
            file: file,
            name: file.name,
            size: file.size,
            progress: 0,
            uploading: false,
            done: false,
            error: null
          });
        }
        event.target.value = '';
      },

      handleDrop(event) {
        this.dragover = false;
        for (var i = 0; i < event.dataTransfer.files.length; i++) {
          var file = event.dataTransfer.files[i];
          this.files.push({
            id: ++idCounter,
            file: file,
            name: file.name,
            size: file.size,
            progress: 0,
            uploading: false,
            done: false,
            error: null
          });
        }
      },

      removeFile(index) {
        this.files.splice(index, 1);
      },

      async uploadAll() {
        this.uploading = true;
        var pending = this.files.filter(function(f) { return !f.done && !f.error; });

        for (var i = 0; i < pending.length; i++) {
          var item = pending[i];
          this.uploadingText = 'Uploading ' + (i + 1) + ' of ' + pending.length + '\u2026';
          item.uploading = true;
          try {
            await this.uploadFile(item);
            item.done = true;
          } catch (e) {
            item.error = e.message || 'Failed';
          }
          item.uploading = false;
        }

        this.uploading = false;
        var successCount = this.files.filter(function(f) { return f.done; }).length;

        if (successCount > 0) {
          this.allDone = true;
          var msg = encodeURIComponent(
            successCount + ' file' + (successCount !== 1 ? 's' : '') + ' uploaded'
          );
          setTimeout(function() {
            window.location.href = redirectPath + '?success=' + msg;
          }, 800);
        }
      },

      uploadFile(item) {
        return new Promise(function(resolve, reject) {
          var xhr = new XMLHttpRequest();
          var formData = new FormData();
          formData.append('file', item.file);

          xhr.upload.addEventListener('progress', function(e) {
            if (e.lengthComputable) {
              item.progress = Math.round((e.loaded / e.total) * 100);
            }
          });

          xhr.addEventListener('load', function() {
            if (xhr.status >= 200 && xhr.status < 300) {
              resolve();
            } else {
              reject(new Error('Upload failed (' + xhr.status + ')'));
            }
          });

          xhr.addEventListener('error', function() {
            reject(new Error('Network error'));
          });

          xhr.open('POST', endpoint);
          xhr.setRequestHeader('Accept', 'application/json');
          xhr.send(formData);
        });
      },

      formatSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(1) + ' MB';
      }
    };
  }
  </script>
{% endblock %}
