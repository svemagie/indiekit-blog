{% call widget({
  title: __("github.title")
}) %}
  <p class="prose">{{ __("github.widget.description") }}</p>
  <div class="button-grid">
    {{ button({
      classes: "button--secondary-on-offset",
      href: application.githubEndpoint or "/github-api",
      text: __("github.widget.view")
    }) }}
  </div>
{% endcall %}
